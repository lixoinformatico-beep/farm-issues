# === Base de dados (MongoDB Atlas - ClusterMyg) ===
MONGO_URL=mongodb+srv://USER:PASSWORD@clustermyg.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=farma_issues

# === Auth ===
JWT_SECRET=cola-aqui-o-secret-gerado
# Admin criado automaticamente no primeiro arranque:
ADMIN_EMAIL=admin@premiumfarma.pt
ADMIN_PASSWORD=muda-isto-no-primeiro-login

# === CORS (URL EXATO do frontend no Vercel, sem barra final) ===
CORS_ORIGINS=https://farm-issues.vercel.app

# === Cookies cross-domain (deixa assim para producao) ===
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# === Storage de anexos (Cloudflare R2) ===
R2_ENDPOINT_URL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=farma-issues
APP_NAME=farma-issues

# === Email (Resend) ===
RESEND_API_KEY=re_xxxxxxxx
SENDER_EMAIL=notificacoes@teudominio.pt
